{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env", ".env.local", "tsconfig.base.json"],
  "globalEnv": [
    "NODE_ENV",
    "CI",
    "VERCEL",
    "VERCEL_ENV",
    "VERCEL_URL",
    "WEB_PORT",
    "ADMIN_PORT",
    "DATABASE_URL",
    "DIRECT_URL",
    "NEXTAUTH_SECRET",
    "NEXTAUTH_URL",
    "NEXT_PUBLIC_APP_URL",
    "NEXT_PUBLIC_ADMIN_URL",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_POSTHOG_KEY",
    "NEXT_PUBLIC_POSTHOG_HOST",
    "NEXT_PUBLIC_SENTRY_DSN",
    "REDIS_URL",
    "SMS_PROVIDER",
    "SMS_PROVIDER_API_KEY",
    "SMS_PROVIDER_API_SECRET",
    "SMS_PROVIDER_SENDER_ID",
    "SMS_OTP_TTL_SECONDS",
    "SMS_OTP_LENGTH",
    "S3_ENDPOINT",
    "S3_REGION",
    "S3_BUCKET",
    "S3_ACCESS_KEY_ID",
    "S3_SECRET_ACCESS_KEY",
    "S3_PUBLIC_BASE_URL",
    "MEILI_HOST",
    "MEILI_MASTER_KEY",
    "IYZICO_API_KEY",
    "IYZICO_SECRET_KEY",
    "IYZICO_BASE_URL",
    "PLATFORM_COMMISSION_BPS",
    "SENTRY_DSN",
    "SENTRY_ORG",
    "SENTRY_PROJECT",
    "POSTHOG_KEY",
    "POSTHOG_HOST",
    "EMAIL_FROM",
    "SMTP_HOST",
    "SMTP_PORT",
    "SMTP_USER",
    "SMTP_PASS",
    "FEATURE_FARM_VISITS",
    "FEATURE_SUBSCRIPTION_BOXES",
    "FEATURE_B2B"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**",
        "build/**",
        "storybook-static/**"
      ],
      "env": [
        "DATABASE_URL",
        "DIRECT_URL",
        "NEXTAUTH_SECRET",
        "NEXTAUTH_URL",
        "NEXT_PUBLIC_APP_URL",
        "NEXT_PUBLIC_API_URL",
        "REDIS_URL",
        "MEILI_HOST",
        "MEILI_MASTER_KEY",
        "S3_ENDPOINT",
        "S3_BUCKET",
        "S3_ACCESS_KEY_ID",
        "S3_SECRET_ACCESS_KEY",
        "IYZICO_API_KEY",
        "IYZICO_SECRET_KEY",
        "IYZICO_BASE_URL",
        "SMS_PROVIDER_API_KEY",
        "SMS_PROVIDER_SENDER_ID",
        "SENTRY_DSN",
        "POSTHOG_KEY",
        "POSTHOG_HOST"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "clean": {
      "cache": false
    },
    "@sanda/db#generate": {
      "cache": false,
      "outputs": ["generated/**", "node_modules/.prisma/**"]
    },
    "@sanda/db#migrate": {
      "cache": false,
      "persistent": false
    }
  }
}
