{
  "name": "sanda",
  "version": "0.1.0",
  "private": true,
  "description": "Sanda — a transparent farm-to-table marketplace for Turkey.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "node ./scripts/with-root-env.mjs turbo run build",
    "dev": "node ./scripts/with-root-env.mjs turbo run dev --parallel --filter=!@sanda/mobile",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yaml,yml}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,yaml,yml}\" --ignore-path .gitignore",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "node ./scripts/with-root-env.mjs pnpm --filter @sanda/db generate",
    "db:migrate": "node ./scripts/with-root-env.mjs pnpm --filter @sanda/db migrate:deploy",
    "db:migrate:dev": "node ./scripts/with-root-env.mjs pnpm --filter @sanda/db migrate",
    "db:seed": "node ./scripts/with-root-env.mjs pnpm --filter @sanda/db seed",
    "db:studio": "node ./scripts/with-root-env.mjs pnpm --filter @sanda/db studio",
    "db:reset": "node ./scripts/with-root-env.mjs pnpm --filter @sanda/db reset",
    "infra:up": "docker compose --env-file .env -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose --env-file .env -f infra/docker-compose.yml down",
    "infra:logs": "docker compose --env-file .env -f infra/docker-compose.yml logs -f",
    "infra:reset": "docker compose --env-file .env -f infra/docker-compose.yml down -v && pnpm infra:up",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "turbo": "^2.2.3",
    "typescript": "^5.6.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  }
}
