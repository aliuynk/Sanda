{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Sanda React Native (Expo)",
  "extends": "./base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "dom"],
    "jsx": "react-jsx",
    "noEmit": true,
    "allowJs": true,
    "moduleResolution": "bundler",
    "types": ["expo/types"]
  }
}
