# =============================================================================
# Sanda — example environment file.
# Copy to .env (monorepo root) and fill in values for local development.
# =============================================================================

# ------ App URLs ------
WEB_PORT="3000"
ADMIN_PORT="3001"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_ADMIN_URL="http://localhost:3001"
NEXT_PUBLIC_API_URL="http://localhost:3000/api/trpc"
NODE_ENV="development"

# ------ Docker-exposed local ports ------
POSTGRES_HOST_PORT="5433"
REDIS_HOST_PORT="6379"
MEILI_HOST_PORT="7700"
MINIO_API_HOST_PORT="9000"
MINIO_CONSOLE_HOST_PORT="9001"
SMTP_HOST_PORT="1025"
MAILHOG_UI_HOST_PORT="8025"

# ------ Database (PostgreSQL + PostGIS) ------
# The pooled connection used at runtime.
DATABASE_URL="postgresql://sanda:sanda@localhost:5433/sanda?schema=public"
# Direct (unpooled) connection used by Prisma Migrate.
DIRECT_URL="postgresql://sanda:sanda@localhost:5433/sanda?schema=public"

# ------ Redis (queues, cache, rate limiting) ------
REDIS_URL="redis://localhost:6379"

# ------ Auth ------
# 32+ bytes, base64. Generate with: openssl rand -base64 48
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"
# How long an SMS OTP code is valid for, in seconds.
SMS_OTP_TTL_SECONDS="300"
SMS_OTP_LENGTH="6"

# ------ SMS provider (NetGSM / İletimerkezi) ------
SMS_PROVIDER="netgsm"
SMS_PROVIDER_API_KEY=""
SMS_PROVIDER_API_SECRET=""
SMS_PROVIDER_SENDER_ID="SANDA"

# ------ Object storage (Cloudflare R2 / S3-compatible) ------
S3_ENDPOINT="http://localhost:9000"
S3_REGION="auto"
S3_BUCKET="sanda-dev"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_BASE_URL="http://localhost:9000/sanda-dev"

# ------ Search (Meilisearch) ------
MEILI_HOST="http://localhost:7700"
MEILI_MASTER_KEY="sanda-dev-master-key"

# ------ Payments (iyzico Marketplace) ------
IYZICO_API_KEY=""
IYZICO_SECRET_KEY=""
IYZICO_BASE_URL="https://sandbox-api.iyzipay.com"
PLATFORM_COMMISSION_BPS="1000" # 1000 bps = 10.00 %

# ------ Observability ------
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
POSTHOG_KEY=""
POSTHOG_HOST="https://eu.posthog.com"

# ------ Email (transactional) ------
EMAIL_FROM="Sanda <no-reply@sanda.tr>"
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASS=""

# ------ Feature flags ------
FEATURE_FARM_VISITS="true"
FEATURE_SUBSCRIPTION_BOXES="false"
FEATURE_B2B="false"
